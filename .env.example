# Sepolia RPC (admin wallet + public reads)
NEXT_PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_CHAIN_ID=11155111

# Deployed Election.sol address on Sepolia
NEXT_PUBLIC_ELECTION_ADDRESS=0xYOUR_ELECTION_CONTRACT_ADDRESS

# Citizen auth (Privy) — mounted from root layout
NEXT_PUBLIC_PRIVY_APP_ID=YOUR_PRIVY_APP_ID
# Server-only — App Secret from Privy Dashboard (Settings)
PRIVY_APP_SECRET=YOUR_PRIVY_APP_SECRET
# Optional: paste verification key to skip remote JWKS fetch
# PRIVY_VERIFICATION_KEY=

# Skip Postgres allowlist while developing cast-vote (still requires Privy auth)
ELIGIBILITY_SKIP_ALLOWLIST=true

# Admin wallet auth (RainbowKit / WalletConnect) — used only under /admin
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID

# Database (Postgres)
DATABASE_URL=postgres://user:password@localhost:5432/civic_vote

# Backend eligibility signer (Sepolia) — NOT the admin's interactive wallet.
# Used only by the server to EIP-712-sign vote tickets after Postgres allowlist checks.
# The matching address is stored on-chain as Election.adminSigner.
ADMIN_SIGNER_PRIVATE_KEY=0xYOUR_ADMIN_SIGNER_PRIVATE_KEY

# Exa AI — party research (server-side)
EXA_API_KEY=YOUR_EXA_API_KEY
